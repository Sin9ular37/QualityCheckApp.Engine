<Window x:Class="QualityCheckApp.Engine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        mc:Ignorable="d"
        Title="质检地图工作台"
        Height="820"
        Width="1440"
        MinHeight="720"
        MinWidth="1180"
        Background="#FFF4F7FB">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF000000" />
        <SolidColorBrush x:Key="PageSurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="#FFF7FAFD" />
        <SolidColorBrush x:Key="AccentSurfaceBrush" Color="#FFE8F3FF" />
        <SolidColorBrush x:Key="AccentStrongSurfaceBrush" Color="#FFD9ECFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFD2DCE7" />
        <SolidColorBrush x:Key="BorderStrongBrush" Color="#FFA9C4DD" />

        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFDFEFF" Offset="0" />
            <GradientStop Color="#FFF1F7FF" Offset="0.55" />
            <GradientStop Color="#FFE3F1FF" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PageSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FFD7EBFF" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource SubtleSurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="WorkbenchTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource SubtleSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                    <Setter Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PageSurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="RowBackground" Value="{StaticResource PageSurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource SubtleSurfaceBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="#FFE1E8F0" />
            <Setter Property="VerticalGridLinesBrush" Value="#FFE1E8F0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF0F5FA" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="22"
                CornerRadius="22"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="1.4*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="质检地图工作台"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="统一入口处理普通 .gdb ZIP 与标准测试包，在同一窗口完成结构检查、图层识别、拓扑检测和地图浏览。"
                               Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />

                    <WrapPanel Margin="0,18,0,0">
                        <Border Margin="0,0,8,8"
                                Padding="10,6"
                                CornerRadius="14"
                                Background="#FFEAF5FF">
                            <TextBlock Text="单入口工作流" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Margin="0,0,8,8"
                                Padding="10,6"
                                CornerRadius="14"
                                Background="#FFEEF8E9">
                            <TextBlock Text="支持标准测试包" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Margin="0,0,8,8"
                                Padding="10,6"
                                CornerRadius="14"
                                Background="#FFEFEFFF">
                            <TextBlock Text="内置地图浏览" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,18,0">
                    <TextBlock Text="推荐流程"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="1. 选择 ZIP 压缩包"
                               Margin="0,12,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="2. 执行结构检查与图层识别"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="3. 在地图中浏览并定位图层"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,8,0"
                            Padding="16"
                            CornerRadius="16"
                            Background="{StaticResource PageSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="发现 .gdb"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="13" />
                            <TextBlock Text="{Binding DetectedGdbCount}"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource MetricValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="4,0"
                            Padding="16"
                            CornerRadius="16"
                            Background="{StaticResource PageSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="识别图层"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="13" />
                            <TextBlock Text="{Binding LayerCount}"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource MetricValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="8,0,0,0"
                            Padding="16"
                            CornerRadius="16"
                            Background="{StaticResource PageSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="当前可见"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="13" />
                            <TextBlock Text="{Binding VisibleLayerCount}"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource MetricValueStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.85*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,16,0"
                    Padding="0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="18,16,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="GIS 地图视图" Style="{StaticResource PanelTitleStyle}" />
                            <TextBlock Text="{Binding PackageMode, StringFormat=当前模式：{0}}"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="放大"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="72"
                                    Click="OnZoomInClick"
                                    IsEnabled="{Binding IsMapReady}" />
                            <Button Content="缩小"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="72"
                                    Click="OnZoomOutClick"
                                    IsEnabled="{Binding IsMapReady}" />
                            <Button Content="全图"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="78"
                                    Margin="0"
                                    Click="OnZoomFullExtentClick"
                                    IsEnabled="{Binding IsMapReady}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="18,0,18,18"
                            CornerRadius="18"
                            Background="#FFF9FBFE"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <wfi:WindowsFormsHost x:Name="MapHost" />

                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="16"
                                    Padding="10,6"
                                    CornerRadius="14"
                                    Background="#EEF6FAFF"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding PackageMode}"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontWeight="SemiBold" />
                            </Border>

                            <TextBlock Text="AxMapControl 加载中..."
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMapReady}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="16"
                                    Padding="10"
                                    CornerRadius="12"
                                    Background="#EEF8FBFF"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding MouseCoordinate}"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontSize="12"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding ScaleInfo}"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="18,0,18,18"
                            Padding="14,10"
                            CornerRadius="14"
                            Background="#FFF3F7FB">
                        <TextBlock Text="地图交互：左键拖动平移，滚轮缩放；双击右侧图层或点击“定位选中”可快速聚焦。"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,12"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="压缩包入口" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="{Binding SelectedZipPathDisplay}"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="支持普通 .gdb ZIP；若压缩包中出现 测试1/测试2/测试3 目录，则自动切换到标准测试包校验模式。"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource MutedTextStyle}" />
                        <WrapPanel Margin="0,16,0,0">
                            <Button Content="选择压缩包"
                                    Width="126"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OnSelectZipClick"
                                    IsEnabled="{Binding IsNotBusy}" />
                            <Button Content="开始检查"
                                    Width="112"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="OnAnalyzeZipClick"
                                    IsEnabled="{Binding IsAnalyzeEnabled}" />
                            <Button Content="清空结果"
                                    Width="102"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0"
                                    Click="OnClearClick"
                                    IsEnabled="{Binding IsNotBusy}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,0,0,12"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="运行状态" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <ProgressBar Height="8"
                                     Margin="0,16,0,0"
                                     IsIndeterminate="{Binding IsBusy}"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,0,0,12"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="结构与识别结果" Style="{StaticResource PanelTitleStyle}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Padding="12"
                                    CornerRadius="14"
                                    Background="{StaticResource SubtleSurfaceBrush}">
                                <StackPanel>
                                    <TextBlock Text="识别模式"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding PackageMode}"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="12"
                                    CornerRadius="14"
                                    Background="{StaticResource SubtleSurfaceBrush}">
                                <StackPanel>
                                    <TextBlock Text="可显示图层"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding DisplayableLayerCount}"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding StructureSummary}"
                                   Margin="0,12,0,0"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Style="{StaticResource CardBorderStyle}">
                    <TabControl Background="Transparent"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                BorderThickness="0"
                                Padding="0">
                        <TabItem Header="图层清单"
                                 Style="{StaticResource WorkbenchTabItemStyle}">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="图层清单" Style="{StaticResource PanelTitleStyle}" />
                                        <TextBlock Text="双击图层可快速定位，勾选“地图可见”可控制地图显示。"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="定位选中"
                                            Width="104"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0"
                                            Click="OnLocateSelectedLayerClick"
                                            IsEnabled="{Binding CanLocateSelectedLayer}" />
                                </Grid>

                                <DataGrid Grid.Row="1"
                                          x:Name="LayersGrid"
                                          Margin="0,16,0,12"
                                          ItemsSource="{Binding Layers}"
                                          SelectedItem="{Binding SelectedLayer}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          GridLinesVisibility="Horizontal"
                                          Background="{StaticResource PageSurfaceBrush}"
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          BorderBrush="{StaticResource BorderBrush}"
                                          AlternatingRowBackground="{StaticResource SubtleSurfaceBrush}"
                                          MouseDoubleClick="OnLayersGridDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="图层名" Binding="{Binding LayerName}" Width="1.8*" />
                                        <DataGridTextColumn Header="几何类型" Binding="{Binding GeometryType}" Width="*" />
                                        <DataGridCheckBoxColumn Header="可显示" Binding="{Binding Displayable}" IsReadOnly="True" Width="74" />
                                        <DataGridCheckBoxColumn Header="地图可见"
                                                                Binding="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="82" />
                                        <DataGridTextColumn Header=".gdb 路径" Binding="{Binding GdbPath}" Width="2.4*" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Grid.Row="2"
                                           Text="旧模块能力已合并到当前主入口，后续操作均在本窗口完成。"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="拓扑问题"
                                 Style="{StaticResource WorkbenchTabItemStyle}">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="拓扑检测" Style="{StaticResource PanelTitleStyle}" />
                                        <TextBlock Text="{Binding SelectedLayerDisplayName, StringFormat=当前图层：{0}}"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>

                                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <Button Content="检测选中图层"
                                                Width="118"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnRunTopologyCheckClick"
                                                IsEnabled="{Binding CanRunTopologyCheck}" />
                                        <Button Content="定位选中问题"
                                                Width="118"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnLocateSelectedTopologyIssueClick"
                                                IsEnabled="{Binding CanLocateSelectedTopologyIssue}" />
                                        <Button Content="清空问题"
                                                Width="96"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0"
                                                Click="OnClearTopologyClick"
                                                IsEnabled="{Binding IsNotBusy}" />
                                    </WrapPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                        Margin="0,16,0,12"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="{StaticResource SubtleSurfaceBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="74"
                                                Height="74"
                                                Margin="0,0,14,0"
                                                CornerRadius="16"
                                                Background="{StaticResource AccentStrongSurfaceBrush}"
                                                BorderBrush="{StaticResource BorderStrongBrush}"
                                                BorderThickness="1">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="问题数"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding TopologyIssueCount}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding TopologySummary}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Border>

                                <DataGrid Grid.Row="2"
                                          x:Name="TopologyIssuesGrid"
                                          ItemsSource="{Binding TopologyIssues}"
                                          SelectedItem="{Binding SelectedTopologyIssue}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          GridLinesVisibility="Horizontal"
                                          Background="{StaticResource PageSurfaceBrush}"
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          BorderBrush="{StaticResource BorderBrush}"
                                          AlternatingRowBackground="{StaticResource SubtleSurfaceBrush}"
                                          MouseDoubleClick="OnTopologyIssuesGridDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="规则" Binding="{Binding RuleName}" Width="108" />
                                        <DataGridTextColumn Header="要素OID" Binding="{Binding FeatureId}" Width="74" />
                                        <DataGridTextColumn Header="相关OID" Binding="{Binding RelatedFeatureId}" Width="74" />
                                        <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Grid.Row="3"
                                           Margin="0,12,0,0"
                                           Text="当前内置规则：全部图层检查空几何；线图层和面图层检查非简单几何；点图层检查重复点；面图层检查面重叠。双击问题可缩放到问题范围。"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.RowSpan="2"
                Background="#66F4F7FB"
                CornerRadius="24"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Padding="18,14"
                        CornerRadius="16"
                        Background="{StaticResource PageSurfaceBrush}"
                        BorderBrush="{StaticResource BorderStrongBrush}"
                        BorderThickness="1">
                    <TextBlock Text="正在处理压缩包，请稍候..."
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               HorizontalAlignment="Center" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
