<Window x:Class="QualityCheckApp.Engine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="质量检查工作台（OutArcGIS）"
        Height="820"
        Width="1440"
        MinHeight="720"
        MinWidth="1180"
        Background="#FFF4F7FB">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF000000" />
        <SolidColorBrush x:Key="PageSurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="#FFF7FAFD" />
        <SolidColorBrush x:Key="AccentSurfaceBrush" Color="#FFE8F3FF" />
        <SolidColorBrush x:Key="AccentStrongSurfaceBrush" Color="#FFD9ECFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFD2DCE7" />
        <SolidColorBrush x:Key="BorderStrongBrush" Color="#FFA9C4DD" />

        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFDFEFF" Offset="0" />
            <GradientStop Color="#FFF1F7FF" Offset="0.55" />
            <GradientStop Color="#FFE3F1FF" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PageSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FFD7EBFF" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource SubtleSurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="WorkbenchTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource SubtleSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                    <Setter Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PageSurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="RowBackground" Value="{StaticResource PageSurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource SubtleSurfaceBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="#FFE1E8F0" />
            <Setter Property="VerticalGridLinesBrush" Value="#FFE1E8F0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF0F5FA" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="22"
                CornerRadius="22"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.4*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="质量检查工作台（OutArcGIS）"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="当前分支已剥离 ArcGIS Engine、ArcObjects、AxMapControl 与官方几何检查工具，保留 ZIP 结构校验，并已接入 GDAL/OGR 图层读取与 NetTopologySuite 几何验证。"
                               Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />

                    <WrapPanel Margin="0,18,0,0">
                        <Border Margin="0,0,8,8"
                                Padding="10,6"
                                CornerRadius="14"
                                Background="#FFEAF5FF">
                            <TextBlock Text="纯 WPF 入口" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Margin="0,0,8,8"
                                Padding="10,6"
                                CornerRadius="14"
                                Background="#FFEEF8E9">
                            <TextBlock Text="无 ArcGIS 运行时" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Margin="0,0,8,8"
                                Padding="10,6"
                                CornerRadius="14"
                                Background="#FFEFEFFF">
                            <TextBlock Text="GDAL 图层读取" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,18,0">
                    <TextBlock Text="当前保留能力"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="1. ZIP 解压与结构校验"
                               Margin="0,12,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="2. .gdb 图层识别与摘要"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="3. 核心元数据与表文件检查"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="4. 开源 GIS 替代骨架"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,8,0"
                            Padding="16"
                            CornerRadius="16"
                            Background="{StaticResource PageSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="发现 .gdb"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="13" />
                            <TextBlock Text="{Binding DetectedGdbCount}"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource MetricValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="4,0"
                            Padding="16"
                            CornerRadius="16"
                            Background="{StaticResource PageSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="结构可用"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="13" />
                            <TextBlock Text="{Binding HealthyLayerCount}"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource MetricValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="8,0,0,0"
                            Padding="16"
                            CornerRadius="16"
                            Background="{StaticResource PageSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="待关注"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="13" />
                            <TextBlock Text="{Binding NeedsAttentionLayerCount}"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource MetricValueStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.65*" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,16,0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="无 ArcGIS 依赖模式" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="这个分支不再尝试加载地图或解析 ArcGIS COM 对象，而是聚焦于 ZIP 结构、GDAL/OGR 图层读取和后续开源 GIS 替换路径。"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Margin="0,0,8,0"
                                Padding="14"
                                CornerRadius="16"
                                Background="{StaticResource SubtleSurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="当前模式" FontSize="12" Foreground="{StaticResource PrimaryTextBrush}" />
                                <TextBlock Text="{Binding PackageMode}"
                                           Margin="0,8,0,0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="4,0"
                                Padding="14"
                                CornerRadius="16"
                                Background="{StaticResource SubtleSurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="选中图层" FontSize="12" Foreground="{StaticResource PrimaryTextBrush}" />
                                <TextBlock Text="{Binding SelectedLayerDisplayName}"
                                           Margin="0,8,0,0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Margin="8,0,0,0"
                                Padding="14"
                                CornerRadius="16"
                                Background="{StaticResource SubtleSurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="几何问题" FontSize="12" Foreground="{StaticResource PrimaryTextBrush}" />
                                <TextBlock Text="{Binding TopologyIssueCount}"
                                           Margin="0,8,0,0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="18"
                            CornerRadius="18"
                            Background="#FFF9FBFE"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="开源地图预览" Style="{StaticResource PanelTitleStyle}" />
                                    <TextBlock Text="Mapsui 当前支持两层预览：一层是真实几何，一层是选中图层/问题的范围框。"
                                               Margin="0,8,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <Border HorizontalAlignment="Right"
                                            Padding="10,6"
                                            CornerRadius="14"
                                            Background="{StaticResource AccentSurfaceBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding PackageMode}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <WrapPanel HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Content="加载真实几何"
                                                Width="112"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnLoadGeometryPreviewClick"
                                                IsEnabled="{Binding CanLoadGeometryPreview}" />
                                        <Button Content="清空预览"
                                                Width="96"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0"
                                                Click="OnClearGeometryPreviewClick"
                                                IsEnabled="{Binding IsNotBusy}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    Margin="0,18,0,0"
                                    CornerRadius="16"
                                    Background="#FFFDFEFF"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid x:Name="PreviewMapHost" />

                                    <Border HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="14"
                                            Padding="10,8"
                                            CornerRadius="12"
                                            Background="#EEF8FBFF"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding MapPreviewSummary}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Width="250" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    CornerRadius="16"
                                    Background="{StaticResource AccentSurfaceBrush}"
                                    BorderBrush="{StaticResource BorderStrongBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="预览说明"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                    <TextBlock Text="1. 点击“加载真实几何”后，会把当前选中图层的真实点/线/面渲染到 Mapsui。"
                                               Margin="0,10,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="2. 蓝色范围框表示当前选中图层的整体范围。"
                                               Margin="0,6,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="3. 红色范围框表示当前选中几何问题的位置范围。"
                                                Margin="0,6,0,0"
                                                Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Margin="0,18,0,0"
                            Padding="14,10"
                            CornerRadius="14"
                            Background="#FFF3F7FB">
                        <TextBlock Text="该工作台适合在无 ArcGIS 环境下做压缩包入库前检查，先识别 ZIP 结构，再读取 GDB 图层并检查几何问题。"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,12"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="压缩包入口" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="{Binding SelectedZipPathDisplay}"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="支持普通 .gdb ZIP；若压缩包中出现 测试1/测试2/测试3 目录，则自动切换到标准测试包校验模式。"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource MutedTextStyle}" />
                        <WrapPanel Margin="0,16,0,0">
                            <Button Content="选择压缩包"
                                    Width="126"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OnSelectZipClick"
                                    IsEnabled="{Binding IsNotBusy}" />
                            <Button Content="开始检查"
                                    Width="112"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="OnAnalyzeZipClick"
                                    IsEnabled="{Binding IsAnalyzeEnabled}" />
                            <Button Content="清空结果"
                                    Width="102"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0"
                                    Click="OnClearClick"
                                    IsEnabled="{Binding IsNotBusy}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,0,0,12"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="运行状态" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <ProgressBar Height="8"
                                     Margin="0,16,0,0"
                                     IsIndeterminate="{Binding IsBusy}"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,0,0,12"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="检查结果" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="{Binding StructureSummary}"
                                   Margin="0,12,0,0"
                                   Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="{Binding TopologySummary}"
                                   Margin="0,12,0,0"
                                   Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="{Binding OpenSourceSkeletonSummary}"
                                   Margin="0,12,0,0"
                                   Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Style="{StaticResource CardBorderStyle}">
                    <TabControl Background="Transparent"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                BorderThickness="0"
                                Padding="0">
                        <TabItem Header="GDB 图层"
                                 Style="{StaticResource WorkbenchTabItemStyle}">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="GDB 图层清单" Style="{StaticResource PanelTitleStyle}" />
                                        <TextBlock Text="每个条目代表 GDAL/OGR 从 .gdb 中枚举到的一个图层；当前已能读取图层名、几何类型与要素数量。"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="检查选中图层"
                                            Width="118"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0"
                                            Click="OnRunTopologyCheckClick"
                                            IsEnabled="{Binding CanRunTopologyCheck}" />
                                </Grid>

                                <DataGrid Grid.Row="1"
                                          Margin="0,16,0,0"
                                          ItemsSource="{Binding Layers}"
                                          SelectedItem="{Binding SelectedLayer}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="名称" Binding="{Binding LayerName}" Width="1.2*" />
                                        <DataGridTextColumn Header="类型" Binding="{Binding DatasetName}" Width="1.1*" />
                                        <DataGridTextColumn Header="内容概览" Binding="{Binding GeometryType}" Width="1.2*" />
                                        <DataGridCheckBoxColumn Header="结构可用" Binding="{Binding Displayable}" Width="78" />
                                        <DataGridTextColumn Header="摘要" Binding="{Binding Summary}" Width="1.7*" />
                                        <DataGridTextColumn Header="路径" Binding="{Binding GdbPath}" Width="2.2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="结构检查"
                                 Style="{StaticResource WorkbenchTabItemStyle}">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="几何检查结果" Style="{StaticResource PanelTitleStyle}" />
                                        <TextBlock Text="这里会输出当前图层的几何检查问题，包括空几何、无效几何、自相交/环自相交和非简单几何。"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>

                                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <Button Content="重新检查"
                                                Width="96"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="OnRunTopologyCheckClick"
                                                IsEnabled="{Binding CanRunTopologyCheck}" />
                                        <Button Content="清空问题"
                                                Width="96"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0"
                                                Click="OnClearTopologyClick"
                                                IsEnabled="{Binding IsNotBusy}" />
                                    </WrapPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                        Margin="0,16,0,12"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="{StaticResource SubtleSurfaceBrush}">
                                    <TextBlock Text="{Binding TopologySummary}"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <DataGrid Grid.Row="2"
                                          ItemsSource="{Binding TopologyIssues}"
                                          SelectedItem="{Binding SelectedTopologyIssue}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="编号" Binding="{Binding FeatureId}" Width="64" />
                                        <DataGridTextColumn Header="规则" Binding="{Binding RuleName}" Width="120" />
                                        <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="开源骨架"
                                 Style="{StaticResource WorkbenchTabItemStyle}">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="开源 GIS 替代骨架" Style="{StaticResource PanelTitleStyle}" />
                                    <TextBlock Text="这一页展示 feature/outarcgis 分支当前已经建立好的替代层接口，便于后续逐步接入真实开源组件。"
                                               Margin="0,6,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Margin="0,16,0,12"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="{StaticResource SubtleSurfaceBrush}">
                                    <TextBlock Text="{Binding OpenSourceSkeletonSummary}"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <Border Grid.Row="2"
                                        Margin="0,0,0,12"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="{StaticResource AccentSurfaceBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="NetTopologySuite WKT 验证"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}" />
                                                <TextBlock Text="这里保留一个独立的 WKT 验证入口，用来单独确认 NetTopologySuite 的几何规则判断行为。"
                                                           Margin="0,6,0,0"
                                                           Style="{StaticResource MutedTextStyle}" />
                                            </StackPanel>

                                            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <Button Content="加载示例"
                                                        Width="96"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="OnLoadSampleWktClick" />
                                                <Button Content="验证 WKT"
                                                        Width="96"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="0"
                                                        Click="OnValidateWktClick" />
                                            </WrapPanel>
                                        </Grid>

                                        <TextBox Grid.Row="1"
                                                 Margin="0,12,0,0"
                                                 MinHeight="92"
                                                 Padding="10"
                                                 Text="{Binding WktInput, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 AcceptsReturn="True" />

                                        <TextBlock Grid.Row="2"
                                                   Margin="0,12,0,0"
                                                   Text="{Binding WktValidationSummary}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="3"
                                                   Margin="0,8,0,0"
                                                   Text="{Binding WktValidationDetail}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Border>

                                <DataGrid Grid.Row="3"
                                          ItemsSource="{Binding OpenSourceModules}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="模块" Binding="{Binding ModuleName}" Width="118" />
                                        <DataGridTextColumn Header="计划组件" Binding="{Binding PlannedLibrary}" Width="110" />
                                        <DataGridTextColumn Header="职责" Binding="{Binding Responsibility}" Width="1.2*" />
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="108" />
                                        <DataGridTextColumn Header="下一步" Binding="{Binding NextStep}" Width="1.25*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.RowSpan="2"
                Background="#66F4F7FB"
                CornerRadius="24"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Padding="18,14"
                        CornerRadius="16"
                        Background="{StaticResource PageSurfaceBrush}"
                        BorderBrush="{StaticResource BorderStrongBrush}"
                        BorderThickness="1">
                    <TextBlock Text="正在处理压缩包，请稍候..."
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               HorizontalAlignment="Center" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
